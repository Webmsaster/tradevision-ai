# =============================================================================
# Multi-Strategy Slot — V5_TITANIUM (long-history validated)
# =============================================================================
# Copy to .env.ftmo.titanium and fill in <PLACEHOLDER> values.
# After filling real tokens: `chmod 600 .env.ftmo.titanium`.
# Designed as 2nd account in 3-strategy multi-account setup
# (slot 1 = R28_V6, slot 2 = V5_TITANIUM, slot 3 = V5_AMBER).
#
# V5_TITANIUM: 14 cryptos, 5.52y / 1985w long-history sample.
# Pass-rate: 58.24% step=1d / 58.16% step=3d / wr 75.76% / TL 0.25%.
# Why: longest-history validated config; uncorrelated to R28_V6's
# (different asset basket, different TP/SL profile). 3-strategy
# min-1-pass math: ~93% with R28_V6 + TITANIUM + AMBER.

# === Strategy Selection ===
FTMO_TF=2h-trend-v5-titanium
FTMO_ACCOUNT_ID=titanium
FTMO_START_BALANCE=100000

# === MT5 Login Validation (R57) ===
FTMO_EXPECTED_LOGIN=<TITANIUM-MT5-LOGIN-NUMBER>

# === Risk Filters ===
REGIME_GATE_ENABLED=true
REGIME_GATE_BLOCK=trend-down
SLIPPAGE_ENTRY_SPREADS=1.5
SLIPPAGE_STOP_SPREADS=3.0

# === Telegram (R57: same bot, separate per-account env-vars) ===
TELEGRAM_BOT_TOKEN_titanium=<SAME-BOT-TOKEN-AS-demo1>
TELEGRAM_CHAT_ID_titanium=<SAME-CHAT-ID-AS-demo1>

# CRITICAL: do NOT set FTMO_TELEGRAM_BOT_MASTER=1 here.
# Only ONE process (demo1/R28_V6) consumes Telegram /getUpdates.
# This account sends-only.

# === Drift Dashboard ===
FTMO_MONITOR_ENABLED=1
# Access: /dashboard/drift?ftmo_tf=2h-trend-v5-titanium-titanium

# === News-Blackout (Round 60 RECOMMENDED) ===
NEWS_BLACKOUT_ENABLED=true
NEWS_BLACKOUT_MIN_BEFORE=30
NEWS_BLACKOUT_MIN_AFTER=60
