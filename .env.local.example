# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (used for sitemap and metadata)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ─── FTMO Bot (optional) ───
# FTMO_MONITOR_ENABLED=1                 # enables /api/ftmo-state etc
# FTMO_MONITOR_AUTH_BYPASS=0             # 1 = skip Supabase auth on monitor routes (single-owner VPS only)
# FTMO_STATE_DIR=ftmo-state              # absolute or relative path
# FTMO_START_BALANCE=100000              # FTMO challenge-account size
# FTMO_TF=2h-trend-v5-r28-v6-passlock    # current champion config
# FTMO_ACCOUNT_ID=demo1                  # multi-account setups (R57)
# FTMO_TELEGRAM_BOT_MASTER=1             # exactly ONE account should set this
# FTMO_NEWS_BLACKOUT_MIN=2               # minutes before high-impact news to flatten
# FF_NEWS_CACHE=scripts/cache_forex/ff_news_cache.json
# NEWS_API_KEY=                          # Finnhub API key (optional, for live news)

# ─── Binance API (optional, for live trade-execution prototypes) ───
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_TESTNET=1                      # 1 = testnet, 0 = production
# BINANCE_RECV_WINDOW=5000               # ms
# BINANCE_LIVE_MODE=0                    # 1 = enable live read endpoints
# BINANCE_LIVE_EXECUTE=0                 # 1 = enable live order placement
# BINANCE_MAX_ORDER_NOTIONAL=100         # USD cap per order in live mode
# EMERGENCY_HALT=0                       # 1 = block all live trades

# ─── Upstash Redis (optional, for distributed rate-limit) ───
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Telegram Bot (optional, for alerts + slash commands) ───
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_ALLOWED_USER_IDS=             # comma-separated user IDs allowed to send commands
