{
  // Phase 81 (R45-CFG-6): noUncheckedIndexedAccess ENABLED globally.
  // Previously 1831 errors blocked global enforcement; cleared via
  // automated `!` injection passes (Phases 79+80) plus targeted manual
  // fixes (Phase 81). All of src/ now compiles clean under
  // noUncheckedIndexedAccess. tsconfig.strict.json is now redundant
  // (kept as a no-op extension for backward compat with `npm run
  // typecheck:strict`).
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "scripts/exploratory", "scripts"]
}
