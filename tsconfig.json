{
  // Phase 78 (R45-CFG-6): noUncheckedIndexedAccess kept OFF in the main
  // tsconfig — re-enabling globally surfaces 1831 errors in src/ alone
  // (heavy array-indexed engine + indicator code); each requires a
  // careful per-loop nullability guard or `!` assertion. See
  // tsconfig.strict.json for the opt-in config used to ratchet new code
  // / individual files toward strict-array-access.
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "scripts/exploratory"]
}
