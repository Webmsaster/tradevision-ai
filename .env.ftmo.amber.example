# =============================================================================
# Multi-Strategy Slot — V5_AMBER (best step=1d anchor)
# =============================================================================
# Copy to .env.ftmo.amber and fill in <PLACEHOLDER> values.
# After filling real tokens: `chmod 600 .env.ftmo.amber`.
# Designed as 3rd account in 3-strategy multi-account setup
# (slot 1 = R28_V6, slot 2 = V5_TITANIUM, slot 3 = V5_AMBER).
#
# V5_AMBER: 14 cryptos, 3.04y / 1103w step=1d.
# Pass-rate: 62.83% step=1d / 61.14% step=3d / wr 81.74% / TL 2%.
# Why: highest step=1d pass-rate in V5 family (high-N robust).
# Asset basket diverges from R28_V6 (BCH/AAVE excluded, INJ/RUNE/SAND in)
# → uncorrelated failure modes. 3-strategy min-1-pass math: ~93%.

# === Strategy Selection ===
FTMO_TF=2h-trend-v5-amber
FTMO_ACCOUNT_ID=amber
FTMO_START_BALANCE=100000

# === MT5 Login Validation (R57) ===
FTMO_EXPECTED_LOGIN=<AMBER-MT5-LOGIN-NUMBER>

# === Risk Filters ===
REGIME_GATE_ENABLED=true
REGIME_GATE_BLOCK=trend-down
SLIPPAGE_ENTRY_SPREADS=1.5
SLIPPAGE_STOP_SPREADS=3.0

# === Telegram (R57: same bot, separate per-account env-vars) ===
TELEGRAM_BOT_TOKEN_amber=<SAME-BOT-TOKEN-AS-demo1>
TELEGRAM_CHAT_ID_amber=<SAME-CHAT-ID-AS-demo1>

# CRITICAL: do NOT set FTMO_TELEGRAM_BOT_MASTER=1 here.
# Only ONE process (demo1/R28_V6) consumes Telegram /getUpdates.
# This account sends-only.

# === Drift Dashboard ===
FTMO_MONITOR_ENABLED=1
# Access: /dashboard/drift?ftmo_tf=2h-trend-v5-amber-amber

# === News-Blackout (Round 60 RECOMMENDED) ===
NEWS_BLACKOUT_ENABLED=true
NEWS_BLACKOUT_MIN_BEFORE=30
NEWS_BLACKOUT_MIN_AFTER=60
