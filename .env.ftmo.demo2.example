# =============================================================================
# Demo 2 — second FTMO Demo Account (multi-account second slot)
# =============================================================================
# Copy to .env.ftmo.demo2 and fill in. Activate AFTER demo1 has 1 stable week.
# After filling real tokens: `chmod 600 .env.ftmo.demo2`.
# Run with: pm2 start ecosystem.config.js --name ftmo-executor-demo2 \
#   --env-from-file .env.ftmo.demo2

# === Strategy Selection ===
FTMO_TF=2h-trend-v5-quartz-lite-r28-v6-v4engine
FTMO_ACCOUNT_ID=demo2
FTMO_START_BALANCE=100000

# === MT5 Login Validation (R57 — different account!) ===
FTMO_EXPECTED_LOGIN=<DEMO2-MT5-LOGIN-NUMBER>

# === Risk Filters (can mirror demo1, or vary slightly to diversify) ===
REGIME_GATE_ENABLED=true
REGIME_GATE_BLOCK=trend-down
SLIPPAGE_ENTRY_SPREADS=1.5
SLIPPAGE_STOP_SPREADS=3.0

# === Telegram (R57 multi-account: per-account token+chat allowed) ===
# Option A: same bot, same chat (alerts get [acct:demo2] prefix from R57)
TELEGRAM_BOT_TOKEN_demo2=<SAME-BOT-TOKEN-AS-demo1>
TELEGRAM_CHAT_ID_demo2=<SAME-CHAT-ID-AS-demo1>

# Option B: separate bot for demo2 (uncomment + comment out Option A)
# TELEGRAM_BOT_TOKEN_demo2=<demo2-bot-token>
# TELEGRAM_CHAT_ID_demo2=<demo2-chat-id>

# CRITICAL: do NOT set FTMO_TELEGRAM_BOT_MASTER=1 here.
# Only demo1 consumes Telegram /getUpdates long-poll. demo2 sends alerts only.
# FTMO_TELEGRAM_BOT_MASTER NOT SET (intentionally)

# === Drift Dashboard (separate state-dir, same shared dashboard URL) ===
FTMO_MONITOR_ENABLED=1
# Access: /dashboard/drift?ftmo_tf=2h-trend-v5-quartz-lite-r28-v6-v4engine-demo2
